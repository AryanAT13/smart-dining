# =============================================================================
# Smart Dining Assistant — environment contract
# -----------------------------------------------------------------------------
# Copy this file to `.env` for local development.
# Production secrets live in Render (gateway) and Vercel (web). Never commit.
# The Zod schema at packages/core/src/config/env.ts is the source of truth —
# if a variable changes here, change it there too.
# =============================================================================

# ----- Runtime -----
NODE_ENV=development
# Set to "true" to expose /debug/trace and the demo trace panel in the UI.
# MUST be false in production.
NEXT_PUBLIC_DEMO_MODE=true

# ----- URLs -----
# Public URL of the Next.js app (used for CORS, SSE absolute URLs, OG metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL of the Socket.io gateway (Render Web Service in prod).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
# Port the gateway listens on locally.
GATEWAY_PORT=4000
# Origin allowed by the gateway's CORS check.
GATEWAY_CORS_ORIGIN=http://localhost:3000

# ----- Database (Render Postgres in prod, Docker locally) -----
# Pooled connection for application queries.
DATABASE_URL=postgresql://dining:dining@localhost:5432/dining?schema=public
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_DATABASE_URL=postgresql://dining:dining@localhost:5432/dining?schema=public

# ----- Cache + Pub/Sub (Render Key-Value in prod, Docker locally) -----
REDIS_URL=redis://localhost:6379

# ----- OpenAI -----
OPENAI_API_KEY=sk-replace-me
# Embedding model for menu RAG. Stay on text-embedding-3-small unless you
# regenerate all embeddings.
EMBEDDING_MODEL=text-embedding-3-small
# Fast model: router, multilingual NLU, upsell, sentiment.
LLM_MODEL_FAST=gpt-4o-mini
# Deep model: recommendation, group coordinator, order validation.
LLM_MODEL_DEEP=gpt-4o
# Per-session spend cap in USD. AI degrades to deterministic fallback past this.
SESSION_LLM_BUDGET_USD=1.50

# ----- LangSmith (agent trace visualisation) -----
# Optional. Leave LANGCHAIN_TRACING_V2 unset to disable.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2-replace-me
LANGCHAIN_PROJECT=smart-dining-dev

# ----- OTP -----
# `mock` accepts 123456 in any non-prod env. `twilio` uses Verify.
OTP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ----- Object storage (menu images) -----
# Cloudflare R2 (S3-compatible). Free egress, fits the spec's CDN requirement.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=smart-dining-menu
# Public CDN URL prefix; images are served via `${R2_PUBLIC_URL}/<key>`.
R2_PUBLIC_URL=http://localhost:3000/menu-images

# ----- Crypto -----
# Used to HMAC-sign OTP codes; rotate per environment.
JWT_SECRET=dev-only-replace-me-with-32-bytes-of-randomness
# Used to HMAC-hash phone numbers in logs and the users table (per §12.4).
PII_HASH_SECRET=dev-only-replace-me-with-32-bytes-of-randomness

# ----- Rate limiting -----
RATE_LIMIT_GLOBAL_PER_MIN=60
RATE_LIMIT_AI_PER_MIN=20

# ----- Restaurant branding (single-tenant defaults) -----
RESTAURANT_NAME=Zaika
ASSISTANT_NAME=Zara
RESTAURANT_TIMEZONE=Asia/Kolkata
