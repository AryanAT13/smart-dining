{
  "name": "smart-dining",
  "private": true,
  "version": "0.1.0",
  "description": "AI-Driven Smart Dining Assistant — multi-agent orchestration over a real-time group ordering platform.",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "eval": "pnpm --filter @smart-dining/core eval",
    "db:generate": "pnpm --filter @smart-dining/core prisma:generate",
    "db:migrate": "pnpm --filter @smart-dining/core prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @smart-dining/core prisma:migrate",
    "db:seed": "pnpm --filter @smart-dining/core db:seed",
    "db:studio": "pnpm --filter @smart-dining/core prisma:studio",
    "db:reset": "pnpm --filter @smart-dining/core prisma:reset",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "infra:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.6",
    "typescript": "^5.5.3"
  }
}
