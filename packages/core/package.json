{
  "name": "@smart-dining/core",
  "version": "0.1.0",
  "private": true,
  "description": "Domain core: agents, orchestrator, tools, services, Prisma client. Consumed by apps/web and apps/gateway.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agents": "./src/agents/index.ts",
    "./orchestrator": "./src/orchestrator/index.ts",
    "./tools": "./src/tools/index.ts",
    "./services": "./src/services/index.ts",
    "./memory": "./src/memory/index.ts",
    "./llm": "./src/llm/index.ts",
    "./config": "./src/config/env.ts",
    "./types": "./src/types/index.ts",
    "./prisma": "./src/db/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "eval": "tsx tests/eval/run.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@langchain/core": "^0.3.5",
    "@langchain/langgraph": "^0.2.16",
    "@langchain/openai": "^0.3.6",
    "@prisma/client": "^5.18.0",
    "ioredis": "^5.4.1",
    "langchain": "^0.3.2",
    "openai": "^4.62.1",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prisma": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
