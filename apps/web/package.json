    "@radix-ui/react-toast": "^1.2.1",
    "@smart-dining/core": "workspace:*",
    "@smart-dining/shared": "workspace:*",
    "@tanstack/react-query": "^5.55.0",
    "class-variance-authority": "^0.7.0",
