{
  "name": "@smart-dining/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Socket.io WebSocket gateway. Subscribes to Redis pub/sub and fans events out to connected diners.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@smart-dining/core": "workspace:*",
    "@smart-dining/shared": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
